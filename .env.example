# Symfony
APP_ENV=prod
APP_SECRET=change-me-generate-with-openssl-rand-hex-32

# Database (MySQL 8)
DATABASE_URL=mysql://caert:change-me@127.0.0.1:3306/caert_db?serverVersion=8.0&charset=utf8mb4

# Mailer (optional — password reset, notifications)
MAILER_DSN=null://null

# Docker Compose overrides (optional)
MYSQL_DATABASE=caert_db
MYSQL_USER=caert
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Deployment / ops
APP_URL=https://caert.example.org
BACKUP_DIR=var/backups
RUN_SMOKE=0
