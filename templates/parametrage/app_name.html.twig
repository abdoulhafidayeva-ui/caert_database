{% extends 'base.html.twig' %}

{% block title %}{{ 'install.welcome_title'|trans }}{% endblock %}

{% block body %}
    <div class="wrapper">
      <div class="abs-center wd-xl">
         <!-- START card-->
         <div class="d-flex justify-content-center">
            <div class="p-2">{{ 'install.welcome_title'|trans }}</div>
         </div>
         <div class="card b0">
            <div class="card-body">
               <p class="text-center">{{ 'install.welcome_subtitle'|trans }}</p>
               {{ form_start(form) }}
                        {# {{ form_row(form.name) }} #}
                    {{ form_rest(form) }}
                    <button class="btn btn-block btn-primary mt-3 col-lg-4 float-right" type="submit" formnovalidate>{{ 'common.next'|trans }}</button>
                {{ form_end(form) }}
            </div>
         </div><!-- END card-->
         {% include "_short_footer.html.twig" %}
      </div>
   </div>
{% endblock %}
