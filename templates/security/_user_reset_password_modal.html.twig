<div class="modal fade caert-modal" id="userResetPasswordModal" role="dialog" aria-labelledby="userResetPasswordModalTitle" aria-hidden="true" inert>
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post" id="userResetPasswordForm" action="#" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="userResetPasswordModalTitle">Nouveau mot de passe</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fermer"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">
                        Définir un nouveau mot de passe pour <strong id="userResetPasswordName"></strong>
                        (<span id="userResetPasswordEmail"></span>).
                    </p>
                    <input type="hidden" name="_token" id="userResetPasswordToken" value="">
                    <div class="d-flex flex-wrap align-items-center mb-3">
                        <button type="button" class="btn btn-sm btn-outline-primary mr-2 mb-2" id="userResetPasswordGenerate">
                            <em class="fas fa-dice fa-fw"></em> Générer un mot de passe
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary mr-2 mb-2" id="userResetPasswordToggleVisibility" aria-label="Afficher le mot de passe" title="Afficher le mot de passe">
                            <em class="fas fa-eye fa-fw" id="userResetPasswordToggleIcon" aria-hidden="true"></em>
                            <span id="userResetPasswordToggleLabel">Afficher</span>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary mb-2" id="userResetPasswordCopy" aria-label="Copier le mot de passe" title="Copier le mot de passe">
                            <em class="fas fa-copy fa-fw" id="userResetPasswordCopyIcon" aria-hidden="true"></em>
                            <span id="userResetPasswordCopyLabel">Copier</span>
                        </button>
                    </div>
                    <div class="form-group mb-0">
                        <label for="userResetPasswordPlain">Mot de passe</label>
                        <input type="password" class="form-control caert-reset-password-field" id="userResetPasswordPlain" name="plainPassword" required minlength="6" autocomplete="new-password" placeholder="Au moins 6 caractères">
                    </div>
                    <div class="custom-control custom-checkbox mt-3 mb-0">
                        <input type="checkbox" class="custom-control-input" id="userResetPasswordSendEmail" name="send_email" value="1">
                        <label class="custom-control-label" for="userResetPasswordSendEmail">Envoyer le mot de passe par e-mail à l'utilisateur</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary" data-loading-label="Enregistrement…">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>
