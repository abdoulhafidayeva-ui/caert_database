{% extends 'base.html.twig' %}

{% block body_class %}caert-app caert-auth{% endblock %}
{% block title %}{{ 'auth.login_title'|trans }}{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="caert-auth-shell">
        <div class="caert-auth-card">
            <div class="caert-auth-brand">
                {% include '_brand_logo.html.twig' with { brand_logo_class: 'caert-brand-logo--auth' } %}
                <h1>{{ 'brand.name'|trans }}</h1>
                <p>{{ 'auth.platform'|trans }}</p>
            </div>
            <div class="caert-auth-body">
                <!-- <div class="d-flex justify-content-end mb-3">
                    {% include '_locale_switcher.html.twig' %}
                </div> -->
                {% include "_flash_message.html.twig" %}
                <form method="POST" novalidate>
                    <div class="form-group">
                        <label for="loginEmail">{{ 'auth.email'|trans }}</label>
                        <div class="input-group">
                            <input class="form-control" id="loginEmail" name="email" type="email"
                                   placeholder="{{ 'auth.email_placeholder'|trans }}"
                                   value="{{ app.session.get(constant('App\\Controller\\SecurityController::LAST_EMAIL')) }}"
                                   autocomplete="email" required>
                            <div class="input-group-append">
                                <span class="input-group-text"><em class="fa fa-envelope text-muted"></em></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="loginPassword">{{ 'auth.password'|trans }}</label>
                        <div class="input-group with-focus">
                            <input class="form-control border-right-0" id="loginPassword" name="password" type="password" placeholder="••••••••" required>
                            <div class="input-group-append">
                                <span class="input-group-text text-muted bg-transparent border-left-0"><em class="fa fa-lock"></em></span>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token('login_form') }}">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="checkbox c-checkbox mb-0">
                            <label class="mb-0 small">
                                <input type="checkbox" name="_remember_me">
                                <span class="fa fa-check"></span> {{ 'auth.remember_me'|trans }}
                            </label>
                        </div>
                        <a class="small" href="{{ path('app_forgotten_password') }}">{{ 'auth.forgot_password'|trans }}</a>
                    </div>
                    <button class="btn btn-primary btn-block" type="submit" data-loading-label="{{ 'auth.sign_in_loading'|trans }}">{{ 'auth.sign_in'|trans }}</button>
                </form>
            </div>
            <div class="caert-auth-footer">
                <a href="{{ path('app_user_register') }}">{{ 'auth.create_account'|trans }}</a>
            </div>
        </div>
        <p class="text-center text-white-50 small mt-3 mb-0">&copy; {{ 'now'|date('Y') }} {{ 'brand.name'|trans }}</p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/caert-auth-form.js') }}"></script>
    {% include 'security/_password_toggle.html.twig' %}
{% endblock %}
