{% extends 'base.html.twig' %}

{% block title %}{{ 'analytics.title'|trans }}{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>{{ 'analytics.title'|trans }} <small>{{ 'analytics.subtitle'|trans }}</small></div>
                <div class="ml-auto">
                    {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-sm btn-outline-primary" href="{{ path('executive_dashboard') }}">
                        <em class="fas fa-chart-bar"></em> {{ 'nav.executive'|trans }}
                    </a>
                    {% endif %}
                    <a class="btn btn-sm btn-secondary" href="{{ path('app_map') }}">
                        <em class="fas fa-map-marked-alt"></em> {{ 'nav.map'|trans }}
                    </a>
                </div>
            </div>
            {% include "_flash_message.html.twig" %}

            <div class="caert-panel mb-4">
                <div class="caert-panel-header">
                    <em class="fas fa-sliders-h"></em> {{ 'analytics.filter_settings'|trans }}
                </div>
                <div class="caert-panel-body">
                    {% include "graphique/_filter_searchTrend2PageForm.html.twig" %}
                </div>
            </div>

            <div class="caert-panel mb-3">
                <div class="caert-panel-body py-3">
                    <form id="analyticsSummaryPeriodForm" class="caert-executive-year-filter form-inline m-0" onsubmit="return false;">
                        <label for="analyticsSummaryYear" class="mr-2 mb-0 small text-muted font-weight-bold">
                            {{ 'analytics.summary_filter.period'|trans }}
                        </label>
                        <select id="analyticsSummaryYear" class="form-control form-control-sm" data-default="{{ summaryPeriodDefault }}">
                            <option value="last12" selected>{{ 'analytics.summary_filter.last_12_months'|trans }}</option>
                            <option value="all">{{ 'executive.filter.all_years'|trans }}</option>
                            {% for year in availableYears %}
                                <option value="{{ year }}">{{ year }}</option>
                            {% endfor %}
                        </select>
                    </form>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="caert-panel caert-chart-panel h-100 mb-0">
                        <div class="caert-panel-header">
                            <em class="fas fa-chart-bar"></em> {{ 'analytics.chart.incidents_count'|trans }}
                        </div>
                        <div class="caert-panel-body">
                            <canvas id="nbTerroristIncidents"></canvas>
                            <p id="nbTerroristIncidentsEmpty" class="text-muted small mb-0 d-none">{{ 'analytics.chart.empty_period'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 mb-4">
                    <div class="caert-panel caert-chart-panel h-100 mb-0">
                        <div class="caert-panel-header">
                            <em class="fas fa-bullseye"></em> {{ 'analytics.chart.main_targets'|trans }}
                        </div>
                        <div class="caert-panel-body">
                            <canvas id="prTargetsOfAttacks"></canvas>
                            <p id="prTargetsOfAttacksEmpty" class="text-muted small mb-0 d-none">{{ 'analytics.chart.empty_period'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('vendor/chart.js/chart.min.js') }}"></script>
    <script src="{{ asset('js/caert-graphique.js') }}?v=10"></script>
{% endblock %}
