{% extends 'base.html.twig' %}

{% block title %}Analyses{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>Analyses <small>Tendances &amp; indicateurs</small></div>
                <div class="ml-auto">
                    {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-sm btn-outline-primary" href="{{ path('executive_dashboard') }}">
                        <em class="fas fa-chart-bar"></em> Synthèse
                    </a>
                    {% endif %}
                    <a class="btn btn-sm btn-secondary" href="{{ path('app_map') }}">
                        <em class="fas fa-map-marked-alt"></em> Carte SIG
                    </a>
                </div>
            </div>
            {% include "_flash_message.html.twig" %}

            <div class="caert-panel mb-4">
                <div class="caert-panel-header">
                    <em class="fas fa-sliders-h"></em> Paramètres d'analyse
                </div>
                <div class="caert-panel-body">
                    {% include "graphique/_filter_searchTrend2PageForm.html.twig" %}
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="caert-panel caert-chart-panel h-100 mb-0">
                        <div class="caert-panel-header">
                            <em class="fas fa-chart-bar"></em> Nombre d'incidents terroristes
                        </div>
                        <div class="caert-panel-body">
                            <canvas id="nbTerroristIncidents"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 mb-4">
                    <div class="caert-panel caert-chart-panel h-100 mb-0">
                        <div class="caert-panel-header">
                            <em class="fas fa-bullseye"></em> Cibles principales des attaques
                        </div>
                        <div class="caert-panel-body">
                            <canvas id="prTargetsOfAttacks"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('vendor/chart.js/chart.min.js') }}"></script>
    <script src="{{ asset('js/caert-graphique.js') }}?v=2"></script>
{% endblock %}
