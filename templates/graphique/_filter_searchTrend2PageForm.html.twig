<form id="searchTrend2PageForm"
      class="caert-filter-form"
      action="#"
      novalidate
      onsubmit="return false;"
      data-search-url="{{ path('search_for_graphique') }}"
      data-incidents-url="{{ path('nb_Terrorist_Incidents') }}"
      data-targets-url="{{ path('pr_Targets_Attacks') }}">
    <div class="row">
        <div class="col-md-4 col-sm-6">
            <div class="form-group">
                <label for="start">{{ 'analytics.filter.period1_month'|trans }}</label>
                <input class="form-control" id="start" name="start" type="month" required>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="form-group">
                <label for="end">{{ 'analytics.filter.period2_month'|trans }}</label>
                <input class="form-control" id="end" name="end" type="month">
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="form-group">
                <label for="type">{{ 'analytics.filter.indicator'|trans }}</label>
                <select id="type" name="type" class="form-control select2" required>
                    {% for value, label in types %}
                        <option value="{{ value }}"{% if loop.first %} selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="col-md-8 col-sm-12">
            <div class="form-group">
                <label for="region">{{ 'analytics.filter.regions'|trans }}</label>
                <select id="region" name="region[]" class="form-control select2" multiple required data-placeholder="{{ 'common.select'|trans }}">
                    {% for region in regions %}
                        <option value="{{ region.id }}">{{ region.libelle }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>
    <div class="caert-filter-actions">
        <button id="generateGraphBtn" class="btn btn-primary" type="button">
            <em class="fas fa-chart-line"></em> {{ 'analytics.filter.generate'|trans }}
        </button>
        <button class="btn btn-outline-secondary stopSearchTrend2PageForm" type="button">
            <em class="fas fa-times"></em> {{ 'common.reset'|trans }}
        </button>
    </div>
    <div class="caert-chart-result mt-4" aria-live="polite"></div>
</form>
