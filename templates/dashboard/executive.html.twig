{% extends 'base.html.twig' %}

{% block title %}{{ 'executive.title'|trans }}{% endblock %}

{% set isFr = app.request.locale starts with 'fr' %}
{% set numDec = isFr ? ',' : '.' %}
{% set numSep = isFr ? ' ' : ',' %}

{% macro kpi(value, labelKey, cardClass, valueClass, numDec, numSep) %}
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="caert-kpi-card {{ cardClass|default('') }}">
            <div class="kpi-value {{ valueClass|default('') }}" title="{{ value }}">{{ value|number_format(0, numDec, numSep) }}</div>
            <div class="kpi-label">{{ labelKey|trans }}</div>
        </div>
    </div>
{% endmacro %}

{% import _self as ui %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>
                    {{ 'executive.title'|trans }}
                    <small>
                        {% if isAllYears %}
                            {{ 'executive.subtitle_all_years'|trans }}
                        {% else %}
                            {{ 'executive.subtitle_year'|trans({'%year%': selectedYear}) }}
                        {% endif %}
                    </small>
                </div>
                <div class="ml-auto">
                    <form method="get" action="{{ path('executive_dashboard') }}" class="caert-executive-year-filter form-inline m-0">
                        <label for="executiveYear" class="mr-2 mb-0 small text-muted font-weight-bold">{{ 'executive.filter.year'|trans }}</label>
                        <select id="executiveYear" name="year" class="form-control form-control-sm" onchange="this.form.submit()">
                            <option value="all" {% if isAllYears %}selected{% endif %}>{{ 'executive.filter.all_years'|trans }}</option>
                            {% for year in availableYears %}
                                <option value="{{ year }}" {% if not isAllYears and selectedYear == year %}selected{% endif %}>{{ year }}</option>
                            {% endfor %}
                        </select>
                    </form>
                </div>
            </div>

            <div class="row mb-2">
                {{ ui.kpi(summary.total, 'executive.kpi.total', '', 'text-primary', numDec, numSep) }}
                {{ ui.kpi(summary.published, 'executive.kpi.published', 'kpi-success', 'text-success', numDec, numSep) }}
                {{ ui.kpi(summary.pending, 'executive.kpi.pending', 'kpi-warning', 'text-warning', numDec, numSep) }}
                {{ ui.kpi(summary.rejected, 'executive.kpi.rejected', 'kpi-danger', 'text-danger', numDec, numSep) }}
                {{ ui.kpi(summary.deaths, 'executive.kpi.deaths', 'kpi-purple', '', numDec, numSep) }}
                {{ ui.kpi(summary.injured, 'executive.kpi.injured', 'kpi-info', '', numDec, numSep) }}
            </div>

            <div class="caert-quick-actions mb-4">
                <a href="{{ path('workflow_inbox') }}" class="btn btn-sm btn-warning">
                    <em class="fas fa-inbox"></em> {{ 'nav.workflow'|trans }} {% if summary.pending > 0 %}({{ summary.pending|number_format(0, numDec, numSep) }}){% endif %}
                </a>
                <a href="{{ path('graphique') }}" class="btn btn-sm btn-info"><em class="fas fa-chart-area"></em> {{ 'nav.analytics'|trans }}</a>
                <a href="{{ path('app_map') }}" class="btn btn-sm btn-secondary"><em class="fas fa-map-marked-alt"></em> {{ 'nav.map'|trans }}</a>
                <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-primary"><em class="fas fa-th-large"></em> {{ 'nav.dashboard'|trans }}</a>
            </div>

            {% if topCountries|length > 0 %}
            <div class="caert-panel">
                <div class="caert-panel-header">
                    <em class="fas fa-globe-africa"></em>
                    {% if isAllYears %}
                        {{ 'executive.top_countries'|trans }}
                    {% else %}
                        {{ 'executive.top_countries_year'|trans({'%year%': selectedYear}) }}
                    {% endif %}
                </div>
                <div class="caert-panel-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 caert-summary-table">
                            <thead>
                                <tr>
                                    <th>{{ 'executive.table.country'|trans }}</th>
                                    <th class="text-right">{{ 'executive.table.count'|trans }}</th>
                                    <th class="text-right">{{ 'map.deaths'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in topCountries %}
                                <tr>
                                    <td>{{ row.country }}</td>
                                    <td class="text-right">{{ row.incidentCount|number_format(0, numDec, numSep) }}</td>
                                    <td class="text-right">{{ row.deaths|number_format(0, numDec, numSep) }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="alert alert-light border text-muted mb-0">
                {{ 'executive.empty_period'|trans }}
            </div>
            {% endif %}
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}
