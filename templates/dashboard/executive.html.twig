{% extends 'base.html.twig' %}

{% block title %}{{ 'executive.title'|trans }}{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>{{ 'executive.title'|trans }} <small>{{ 'executive.subtitle'|trans }}</small></div>
            </div>

            <div class="row mb-2">
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card">
                        <div class="kpi-value text-primary">{{ summary.total }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.total'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card kpi-success">
                        <div class="kpi-value text-success">{{ summary.published }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.published'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card kpi-warning">
                        <div class="kpi-value text-warning">{{ summary.pending }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.pending'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card kpi-danger">
                        <div class="kpi-value text-danger">{{ summary.rejected }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.rejected'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card kpi-purple">
                        <div class="kpi-value">{{ summary.deaths }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.deaths'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4 col-lg-2 mb-3">
                    <div class="caert-kpi-card kpi-info">
                        <div class="kpi-value">{{ summary.injured }}</div>
                        <div class="kpi-label">{{ 'executive.kpi.injured'|trans }}</div>
                    </div>
                </div>
            </div>

            <div class="caert-quick-actions mb-4">
                <a href="{{ path('workflow_inbox') }}" class="btn btn-sm btn-warning">
                    <em class="fas fa-inbox"></em> {{ 'nav.workflow'|trans }} {% if summary.pending > 0 %}({{ summary.pending }}){% endif %}
                </a>
                <a href="{{ path('graphique') }}" class="btn btn-sm btn-info"><em class="fas fa-chart-area"></em> {{ 'nav.analytics'|trans }}</a>
                <a href="{{ path('app_map') }}" class="btn btn-sm btn-secondary"><em class="fas fa-map-marked-alt"></em> {{ 'nav.map'|trans }}</a>
                <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-primary"><em class="fas fa-th-large"></em> {{ 'nav.dashboard'|trans }}</a>
            </div>

            {% if topCountries|length > 0 %}
            <div class="caert-panel">
                <div class="caert-panel-header"><em class="fas fa-globe-africa"></em> {{ 'executive.top_countries'|trans }}</div>
                <div class="caert-panel-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 caert-summary-table">
                            <thead>
                                <tr>
                                    <th>{{ 'executive.table.country'|trans }}</th>
                                    <th class="text-right">{{ 'executive.table.count'|trans }}</th>
                                    <th class="text-right">{{ 'map.deaths'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in topCountries %}
                                <tr>
                                    <td>{{ row.country }}</td>
                                    <td class="text-right">{{ row.incidentCount }}</td>
                                    <td class="text-right">{{ row.deaths }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}
