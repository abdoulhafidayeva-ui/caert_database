{% extends 'base.html.twig' %}

{% block title %}Espaces{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            {% include '_partials/referential_list_content.html.twig' with {
                title: 'Espaces',
                subtitle: 'Référentiel',
                backUrl: path('espace'),
                formPanelTitle: 'Ajouter un espace',
                listPanelTitle: 'Liste des espaces',
                tableWrapperId: 'espaceTable-wrapper',
                form: form
            } %}
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('bundles/datatables/js/datatables.js') }}"></script>
<script type="text/javascript">
$(function() {
    $('#espaceTable-wrapper').initDataTables({{ datatable_settings(datatable) }}, {
        buttons: [{ extend: 'excel', className: 'btn btn-warning btn-square' }]
    });
});
</script>
{% endblock %}
