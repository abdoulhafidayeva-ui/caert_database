                $("#formModalView").modal("show");
            } #}
            function formModalView(id){
                $.ajax({
                    method: 'GET',
                    url: Routing.generate('objet_rejet_msg', {id:id}),
                    async: false,
                    success : function (response) {
                        if (response.msg) {
                            Swal.fire(response.msg);
                        }else{ 
                            Swal.fire('Aucun commentaire!');
                        }
                    }
                });
            }

            
        
        
    </script>
{% endblock javascripts %}