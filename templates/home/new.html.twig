{% extends 'base.html.twig' %}

{% block title %}{{ titreFormulaire|default('Enregistrement') }}{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>{{ titreFormulaire|default('Enregistrement') }}<small>Formulaire incident</small></div>
                <div class="ml-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="{{ backUrl|default(path('app_home')) }}">
                        <em class="fas fa-arrow-left"></em> Retour
                    </a>
                </div>
            </div>
            {% include "_flash_message.html.twig" %}
            <div class="caert-panel">
                <div class="caert-panel-header">
                    <em class="fas fa-file-alt"></em> Données de l'incident
                </div>
                <div class="caert-panel-body">
                    {{ include('home/_form.html.twig', {
                        form: form,
                        submitLabel: button|default('Enregistrer'),
                        cancelUrl: backUrl|default(path('app_home'))
                    }) }}
                </div>
            </div>
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}
