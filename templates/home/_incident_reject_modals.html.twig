{# Modals rejet — à inclure hors du .wrapper pour un z-index correct #}

{% set canPublish = is_granted(constant('App\\Security\\Voter\\AllDataVoter::PUBLISH'), incident) %}

{% set isPending = incident.isPublished is null %}

{% set isPublished = incident.isPublished == true %}

{% set isRejected = incident.isPublished == false %}



{% if canPublish and (isPending or isPublished) %}

<div class="modal fade caert-modal" id="rejectModalDetail" tabindex="-1" role="dialog" aria-labelledby="rejectModalDetailTitle" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content">

            <form method="post" action="{{ path('publish_or_not', {allData: incident.id}) }}">

                <input type="hidden" name="_return" value="view">

                <div class="modal-header">

                    <h5 class="modal-title" id="rejectModalDetailTitle">Motif du rejet</h5>

                    <button type="button" class="close" data-dismiss="modal" aria-label="Fermer"><span aria-hidden="true">&times;</span></button>

                </div>

                <div class="modal-body">

                    <label for="rejectMotifDetail" class="text-muted small">Décrivez la raison du rejet (obligatoire)</label>

                    <textarea id="rejectMotifDetail" name="objetRejet" class="form-control" rows="4" required placeholder="Précisez le motif du rejet…"></textarea>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>

                    <button type="submit" class="btn btn-danger">Confirmer le rejet</button>

                </div>

            </form>

        </div>

    </div>

</div>

{% endif %}



{% if isRejected and incident.objetRejet %}

<div class="modal fade caert-modal" id="rejectReasonModal" tabindex="-1" role="dialog" aria-labelledby="rejectReasonModalTitle" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" id="rejectReasonModalTitle">Motif du rejet</h5>

                <button type="button" class="close" data-dismiss="modal" aria-label="Fermer"><span aria-hidden="true">&times;</span></button>

            </div>

            <div class="modal-body">

                <p class="mb-0">{{ incident.objetRejet }}</p>

            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>

            </div>

        </div>

    </div>

</div>

{% endif %}


