{% extends 'base.html.twig' %}

{% block title %}Carte des incidents{% endblock %}

{% block stylesheets %}

    {{ parent() }}

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>#map { height: 65vh; min-height: 400px; border-radius: 4px; }</style>

{% endblock %}

{% block body %}

<div class="wrapper">

    {% include "_header.html.twig" %}

    {% include "_aside.html.twig" %}

    <section class="section-container">

        <div class="content-wrapper">

            <div class="content-heading">

                <div>Cartographie <small>incidents publiés par pays</small></div>

            </div>

            <div class="row mb-3">

                <div class="col-md-4">

                    <div class="caert-kpi-card mb-0">

                        <div class="kpi-value">{{ countryCount }}</div>

                        <div class="kpi-label">Pays concernés</div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="caert-kpi-card mb-0">

                        <div class="kpi-value">{{ incidentCount }}</div>

                        <div class="kpi-label">Incidents publiés</div>

                    </div>

                </div>

            </div>

            <div class="alert alert-info">

                Points positionnés au centroïde du pays. La localité est indiquée dans le détail de chaque incident.

            </div>

            <div class="caert-map-legend">
                <span class="dot"></span> Taille du cercle = volume d'incidents par pays (agrégation au centroïde national)
            </div>

            <div id="map"></div>

        </div>

    </section>

    {% include "_footer.html.twig" %}

</div>

{% endblock %}

{% block javascripts %}

    {{ parent() }}

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>

        const map = L.map('map').setView([2, 20], 3);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {

            maxZoom: 18,

            attribution: '&copy; OpenStreetMap'

        }).addTo(map);



        fetch('{{ path('api_map_countries') }}')

            .then(r => r.json())

            .then(geojson => {

                const layer = L.geoJSON(geojson, {

                    pointToLayer: (feature, latlng) => L.circleMarker(latlng, {

                        radius: Math.min(16, 6 + (feature.properties.count || 1) * 2),

                        fillColor: '#c0392b',

                        color: '#7b241c',

                        weight: 1,

                        fillOpacity: 0.75

                    }),

                    onEachFeature: (feature, layer) => {

                        layer.bindPopup(

                            '<strong>' + feature.properties.country + '</strong><br>' +

                            'Incidents: ' + feature.properties.count + '<br>' +

                            'Décès: ' + feature.properties.deaths

                        );

                    }

                }).addTo(map);

                if (layer.getBounds().isValid()) {

                    map.fitBounds(layer.getBounds(), { padding: [30, 30], maxZoom: 5 });

                }

            });

    </script>

{% endblock %}


