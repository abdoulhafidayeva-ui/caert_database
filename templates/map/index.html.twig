{% extends 'base.html.twig' %}

{% block title %}{{ 'map.title'|trans }}{% endblock %}

{% set isFr = app.request.locale starts with 'fr' %}
{% set numDec = isFr ? ',' : '.' %}
{% set numSep = isFr ? ' ' : ',' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map {
            height: 65vh;
            min-height: 420px;
            border-radius: 8px;
            border: 1px solid var(--caert-border, #e2e8f0);
        }
        .caert-map-legend .dot {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #c0392b;
            margin-right: 6px;
        }
        .leaflet-popup.caert-map-leaflet-popup .leaflet-popup-content-wrapper {
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.14);
            padding: 0;
        }
        .leaflet-popup.caert-map-leaflet-popup .leaflet-popup-content {
            margin: 0;
            min-width: 220px;
        }
        .leaflet-popup.caert-map-leaflet-popup .leaflet-popup-tip {
            box-shadow: none;
        }
        .caert-map-popup {
            padding: 0.9rem 1rem 0.85rem;
        }
        .caert-map-popup__title {
            margin: 0 0 0.75rem;
            font-size: 1rem;
            font-weight: 700;
            line-height: 1.25;
            color: #0f172a;
        }
        .caert-map-popup__stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.45rem;
            margin-bottom: 0.65rem;
        }
        .caert-map-popup__stat {
            text-align: center;
            background: #f8fafc;
            border-radius: 8px;
            padding: 0.55rem 0.35rem;
            border: 1px solid #e2e8f0;
        }
        .caert-map-popup__value {
            display: block;
            font-size: 1.1rem;
            font-weight: 700;
            line-height: 1.1;
            color: #0f172a;
        }
        .caert-map-popup__label {
            display: block;
            margin-top: 0.15rem;
            font-size: 0.68rem;
            color: #64748b;
            line-height: 1.2;
        }
        .caert-map-popup__note {
            margin: 0;
            font-size: 0.72rem;
            color: #64748b;
            line-height: 1.35;
        }
    </style>
{% endblock %}

{% block body %}
<div class="wrapper">
    {% include "_header.html.twig" %}
    {% include "_aside.html.twig" %}
    <section class="section-container">
        <div class="content-wrapper">
            <div class="content-heading">
                <div>
                    {{ 'map.cartography'|trans }}
                    <small>
                        {% if isAllYears %}
                            {{ 'map.subtitle_all_years'|trans }}
                        {% else %}
                            {{ 'map.subtitle_year'|trans({'%year%': selectedYear}) }}
                        {% endif %}
                    </small>
                </div>
                <div class="ml-auto">
                    <form method="get" action="{{ path('app_map') }}" class="caert-executive-year-filter form-inline m-0">
                        <label for="mapYear" class="mr-2 mb-0 small text-muted font-weight-bold">{{ 'executive.filter.year'|trans }}</label>
                        <select id="mapYear" name="year" class="form-control form-control-sm" onchange="this.form.submit()">
                            <option value="all" {% if isAllYears %}selected{% endif %}>{{ 'executive.filter.all_years'|trans }}</option>
                            {% for year in availableYears %}
                                <option value="{{ year }}" {% if not isAllYears and selectedYear == year %}selected{% endif %}>{{ year }}</option>
                            {% endfor %}
                        </select>
                    </form>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="caert-kpi-card mb-0">
                        <div class="kpi-value" title="{{ countryCount }}">{{ countryCount|number_format(0, numDec, numSep) }}</div>
                        <div class="kpi-label">{{ 'map.kpi.countries'|trans }}</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="caert-kpi-card mb-0">
                        <div class="kpi-value" title="{{ incidentCount }}">{{ incidentCount|number_format(0, numDec, numSep) }}</div>
                        <div class="kpi-label">{{ 'map.kpi.published_incidents'|trans }}</div>
                    </div>
                </div>
            </div>
            <div class="alert alert-info py-2">
                {{ 'map.info'|trans }}
            </div>
            <div class="caert-map-legend mb-2">
                <span class="dot"></span> {{ 'map.legend'|trans }}
            </div>
            {% if countryCount > 0 %}
                <div id="map"></div>
            {% else %}
                <div class="alert alert-light border text-muted mb-0">
                    {{ 'map.empty_period'|trans }}
                </div>
            {% endif %}
        </div>
    </section>
    {% include "_footer.html.twig" %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if countryCount > 0 %}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        window.caertMapI18n = {{ {
            incidents: 'map.incidents'|trans,
            deaths: 'map.deaths'|trans,
            injured: 'map.injured'|trans,
            statsScope: 'map.stats_scope'|trans,
        }|json_encode|raw }};
    </script>
    <script src="{{ asset('js/caert-map.js') }}?v=5"></script>
    <script>
        initCaertMap({
            countriesUrl: {{ path('api_map_countries', { year: yearQuery })|json_encode|raw }},
        });
    </script>
    {% endif %}
{% endblock %}
