{% extends 'base.html.twig' %}

{% block title %}{{ 'workflow.title'|trans }}{% endblock %}

{% block body %}

<div class="wrapper">

    {% include "_header.html.twig" %}

    {% include "_aside.html.twig" %}

    <section class="section-container">

        <div class="content-wrapper">

            <div class="content-heading">

                <div>{{ 'workflow.title'|trans }} <small>{{ 'workflow.pending_count'|trans({'%count%': total}) }}</small></div>

                <div class="ml-auto">

                    <a href="{{ path('executive_dashboard') }}" class="btn btn-sm btn-outline-primary">{{ 'executive.title'|trans }}</a>

                </div>

            </div>

            {% include "_flash_message.html.twig" %}

            <div class="caert-panel">
                <div class="caert-panel-header"><em class="fas fa-inbox"></em> {{ 'workflow.pending_panel'|trans }}</div>
                <div class="caert-panel-body table-responsive p-0">
                    <table class="table table-striped table-hover mb-0">

                        <thead>

                            <tr>

                                <th>#</th>

                                <th>{{ 'workflow.table.attack_date'|trans }}</th>

                                <th>{{ 'incident.field.country'|trans }}</th>

                                <th>{{ 'incident.field.locality'|trans }}</th>

                                <th>{{ 'incident.kpi.deaths'|trans }}</th>

                                <th>{{ 'workflow.table.entry_by'|trans }}</th>

                                <th>{{ 'workflow.table.entry_at'|trans }}</th>

                                <th class="text-right">{{ 'user.actions'|trans }}</th>

                            </tr>

                        </thead>

                        <tbody>

                        {% for item in pending %}

                            <tr>

                                <td>{{ ((pending.currentPageNumber - 1) * pending.itemNumberPerPage) + loop.index }}</td>

                                <td>{{ item.dateAttaque ? item.dateAttaque|date('d/m/Y') : '—' }}</td>

                                <td>{{ item.pays ? item.pays.libelle : '—' }}</td>

                                <td>{{ item.localite }}</td>

                                <td><span class="badge badge-danger">{{ item.totalDeces }}</span></td>

                                <td>{{ item.user ? item.user.email : '—' }}</td>

                                <td>{{ item.createdAt|date('d/m/Y H:i') }}</td>

                                <td class="text-right">

                                    <a class="btn btn-sm btn-info" href="{{ path('view_all_data', {allData: item.id, from: 'inbox'}) }}">
                                        <em class="fas fa-eye"></em> {{ 'incident.action.detail'|trans }}
                                    </a>

                                </td>

                            </tr>

                        {% else %}

                            <tr><td colspan="8" class="text-center text-muted py-4">{{ 'workflow.empty'|trans }}</td></tr>

                        {% endfor %}

                        </tbody>

                    </table>
                    {% if pending|length > 0 %}
                    <div class="pagination justify-content-center pb-3">
                        {{ knp_pagination_render(pending) }}
                    </div>
                    {% endif %}
                </div>
            </div>

        </div>

    </section>

    {% include "_footer.html.twig" %}

</div>

{% endblock %}

